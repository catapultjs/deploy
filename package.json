{
  "name": "@catapultjs/deploy",
  "version": "0.0.1-alpha.17",
  "type": "module",
  "main": "build/index.js",
  "bin": {
    "cata": "./build/bin/run.js",
    "catapult": "./build/bin/run.js",
    "catapultjs": "./build/bin/run.js"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/batosai/catapult.git"
  },
  "files": [
    "build"
  ],
  "scripts": {
    "lint": "eslint .",
    "format": "prettier --write .",
    "typecheck": "tsc --noEmit",
    "build": "tsc",
    "prepublishOnly": "npm run build",
    "docs:dev": "vitepress dev docs",
    "docs:build": "vitepress build docs",
    "docs:preview": "vitepress preview docs"
  },
  "author": "Jeremy Chaufourier jeremy@chaufourier.fr",
  "license": "MIT",
  "description": "SSH deployment tool for Node.js applications",
  "keywords": [
    "deploy",
    "deployment",
    "ssh",
    "nodejs",
    "adonisjs",
    "pm2",
    "rsync",
    "cli"
  ],
  "types": "./build/index.d.ts",
  "exports": {
    ".": {
      "types": "./build/index.d.ts",
      "import": "./build/index.js"
    },
    "./recipes/*": {
      "types": "./build/recipes/*.d.ts",
      "import": "./build/recipes/*.js"
    }
  },
  "devDependencies": {
    "@adonisjs/eslint-config": "^3.0.0",
    "@adonisjs/prettier-config": "^1.4.5",
    "@adonisjs/tsconfig": "^2.0.0",
    "@types/node": "^24.12.0",
    "eslint": "^10.1.0",
    "prettier": "^3.8.1",
    "typescript": "^5.9.3",
    "vitepress": "^2.0.0-alpha.17"
  },
  "dependencies": {
    "@adonisjs/ace": "^14.1.0",
    "execa": "^9.6.1"
  },
  "eslintConfig": {
    "extends": "@adonisjs/eslint-config/app"
  },
  "prettier": "@adonisjs/prettier-config",
  "publishConfig": {
    "access": "public",
    "tag": "alpha"
  },
  "engines": {
    "node": ">=24.0.0"
  },
  "volta": {
    "node": "24.13.0"
  }
}
