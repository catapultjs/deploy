{
  "name": "adonisjs-deployer",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "license": "UNLICENSED",
  "scripts": {
    "start": "node bin/server.js",
    "build": "node ace build",
    "dev": "node ace serve --hmr",
    "test": "node ace test",
    "lint": "eslint .",
    "format": "prettier --write .",
    "typecheck": "tsc --noEmit",
    "deploy:setup": "node bin/cli.ts deploy:setup",
    "deploy": "node bin/cli.ts deploy",
    "rollback": "node bin/cli.ts rollback",
    "status": "deployerjs status",
    "deployerjs": "deployerjs",
    "list-releases": "node bin/cli.ts list-releases"
  },
  "imports": {
    "#controllers/*": "./app/controllers/*.js",
    "#exceptions/*": "./app/exceptions/*.js",
    "#models/*": "./app/models/*.js",
    "#mails/*": "./app/mails/*.js",
    "#services/*": "./app/services/*.js",
    "#listeners/*": "./app/listeners/*.js",
    "#generated/*": "./.adonisjs/server/*.js",
    "#events/*": "./app/events/*.js",
    "#middleware/*": "./app/middleware/*.js",
    "#validators/*": "./app/validators/*.js",
    "#providers/*": "./providers/*.js",
    "#policies/*": "./app/policies/*.js",
    "#abilities/*": "./app/abilities/*.js",
    "#database/*": "./database/*.js",
    "#start/*": "./start/*.js",
    "#tests/*": "./tests/*.js",
    "#transformers/*": "./app/transformers/*.js",
    "#config/*": "./config/*.js"
  },
  "devDependencies": {
    "@adonisjs/ace": "^14.1.0",
    "@adonisjs/assembler": "^8.1.0",
    "@adonisjs/eslint-config": "^3.0.0",
    "@adonisjs/prettier-config": "^1.4.5",
    "@adonisjs/tsconfig": "^2.0.0",
    "@catapultjs/deploy": "file:../../catapultjs-deploy-0.5.0.tgz",
    "@japa/assert": "^4.2.0",
    "@japa/plugin-adonisjs": "^5.1.0",
    "@japa/runner": "^5.3.0",
    "@poppinss/ts-exec": "^1.4.4",
    "@types/node": "^25.5.0",
    "eslint": "^10.1.0",
    "hot-hook": "^1.0.0",
    "pino-pretty": "^13.1.3",
    "prettier": "^3.8.1",
    "typescript": "~5.9.3"
  },
  "dependencies": {
    "@adonisjs/core": "^7.1.1",
    "reflect-metadata": "^0.2.2"
  },
  "hotHook": {
    "boundaries": [
      "./app/controllers/**/*.ts",
      "./app/middleware/*.ts"
    ]
  },
  "eslintConfig": {
    "extends": "@adonisjs/eslint-config/app"
  },
  "prettier": "@adonisjs/prettier-config",
  "bundleDependencies": [
    "@adonisjs/core",
    "reflect-metadata"
  ]
}
